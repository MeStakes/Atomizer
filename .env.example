# Atomizer — environment configuration
# Copy this file to ".env" and fill in your keys. All values are OPTIONAL:
# if a key is missing, Atomizer skips the online lookup and uses the local
# (librosa) BPM/key analysis instead.

# --- Online BPM / key lookup ------------------------------------------------
# Atomizer tries online providers first (faster, often more accurate), using the
# track title + artist extracted from yt-dlp metadata, then falls back to local.
#
# GetSongBPM (free, requires attribution backlink). Get a key at:
#   https://getsongbpm.com/api
GETSONGBPM_API_KEY=

# Tunebat / RapidAPI (alternative provider). If you use the RapidAPI proxy,
# set the host too. Leave blank to disable.
#   https://rapidapi.com/  (search "Tunebat")
TUNEBAT_API_KEY=
TUNEBAT_API_HOST=

# Which provider to try first: getsongbpm | tunebat
BPM_KEY_PROVIDER=getsongbpm

# --- Paths (optional; UI overrides these) -----------------------------------
# Default output directory for exported stems.
ATOMIZER_OUTPUT_DIR=~/Music/Atomizer

# Where downloaded source audio is cached.
ATOMIZER_DOWNLOAD_DIR=~/Music/Atomizer/.cache/downloads
